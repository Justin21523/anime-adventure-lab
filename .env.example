# Anime-Adventure-Lab Environment Configuration
# Copy this file to .env and configure for your environment

# ============================================================================
# Warehouse & Cache Configuration
# ============================================================================

# AI model and data warehouse path (REQUIRED)
# This should point to a directory with enough space for models and cache
AI_CACHE_ROOT=/mnt/c/AI_LLM_projects/ai_warehouse

# For Docker, this is the host path that will be mounted
AI_WAREHOUSE_HOST=/mnt/c/AI_LLM_projects/ai_warehouse

# ============================================================================
# API Configuration
# ============================================================================

# API server settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# CORS allowed origins (comma-separated)
API_CORS_ORIGINS=http://localhost:7860,http://localhost:3000

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL connection
DATABASE_URL=postgresql://saga:saga123@localhost:5432/sagaforge
POSTGRES_DB=sagaforge
POSTGRES_USER=saga
POSTGRES_PASSWORD=saga123

# ============================================================================
# Redis Configuration
# ============================================================================

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Redis cache settings
REDIS_MAX_CONNECTIONS=20
REDIS_CACHE_TTL=3600

# ============================================================================
# Object Storage (MinIO/S3)
# ============================================================================

# MinIO/S3 configuration (optional)
MINIO_ENDPOINT=localhost:9000
MINIO_USER=sagaforge
MINIO_PASSWORD=sagaforge123
MINIO_BUCKET=sagaforge
MINIO_USE_SSL=false

# ============================================================================
# AI Model Configuration
# ============================================================================

# Default models
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
EMBEDDING_MODEL=BAAI/bge-m3
T2I_MODEL=stabilityai/stable-diffusion-xl-base-1.0
VLM_MODEL=Salesforce/blip2-opt-2.7b

# Model precision
MODEL_PRECISION=fp16  # or bf16, int8, int4

# Performance settings
ENABLE_XFORMERS=true
ENABLE_ATTENTION_SLICING=false
LOW_VRAM_MODE=false

# ============================================================================
# Performance & Optimization
# ============================================================================

# Quantization mode (none, int8, int4, dynamic)
QUANTIZATION_MODE=int8

# Batch processing
MAX_BATCH_SIZE=32
OPTIMAL_BATCH_SIZE=8
ENABLE_BATCH_DEDUPLICATION=true

# Caching
EMBEDDING_CACHE_TTL=604800  # 7 days in seconds
IMAGE_CACHE_TTL=259200  # 3 days in seconds
ENABLE_KV_CACHE=true

# ============================================================================
# GPU Configuration
# ============================================================================

# CUDA device selection (comma-separated device IDs, or empty for all)
CUDA_VISIBLE_DEVICES=0

# GPU memory settings
GPU_MEMORY_FRACTION=0.9

# ============================================================================
# Celery Worker Configuration
# ============================================================================

# Celery broker URL
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Worker settings
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_TASK_TIME_LIMIT=3600  # 1 hour in seconds

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log

# Enable detailed logging
ENABLE_DEBUG_LOGGING=false

# ============================================================================
# Security Configuration
# ============================================================================

# API authentication (optional)
ENABLE_API_AUTH=false
API_SECRET_KEY=your-secret-key-here-change-in-production

# Rate limiting
API_RATE_LIMIT=100/minute

# Upload limits
MAX_UPLOAD_SIZE_MB=100

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/disable specific features
ENABLE_RAG=true
ENABLE_T2I=true
ENABLE_VLM=true
ENABLE_TRAINING=true
ENABLE_BATCH_JOBS=true

# Safety features
ENABLE_CONTENT_FILTER=true
ENABLE_NSFW_FILTER=true
WATERMARK_IMAGES=false

# ============================================================================
# External Services
# ============================================================================

# HuggingFace token (for private models)
HF_TOKEN=

# Weights & Biases (optional, for training monitoring)
WANDB_API_KEY=
WANDB_PROJECT=anime-adventure-lab

# ============================================================================
# Development Settings
# ============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Enable hot reload
AUTO_RELOAD=true

# Debug mode
DEBUG=false

# ============================================================================
# Monitoring & Observability
# ============================================================================

# Enable Prometheus metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Sentry error tracking (optional)
SENTRY_DSN=

# ============================================================================
# Story & World Configuration
# ============================================================================

# Default world settings
DEFAULT_WORLD_ID=demo_world
MAX_STORY_TURNS=100

# Narrative settings
NARRATIVE_STYLE=balanced  # minimal, balanced, detailed, rich
CHARACTER_CONSISTENCY_CHECK=true

# ============================================================================
# Frontend Configuration
# ============================================================================

# Gradio UI settings
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false

# Theme
GRADIO_THEME=soft

# ============================================================================
# Testing Configuration
# ============================================================================

# Test database (use separate DB for tests)
TEST_DATABASE_URL=postgresql://saga:saga123@localhost:5432/sagaforge_test

# Test settings
RUN_SLOW_TESTS=false
TEST_WITH_REAL_MODELS=false
