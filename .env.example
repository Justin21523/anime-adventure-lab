# Anime-Adventure-Lab Environment Configuration
# Copy this file to .env and configure for your environment

# ============================================================================
# Filesystem & Storage (AI_WAREHOUSE 3.0)
# ============================================================================
# 依照 ~/Desktop/data_model_structure.md：
# - 快取 (HF/torch/pip/XDG) -> /mnt/c/ai_cache
# - 模型 (LoRA/checkpoints/weights) -> /mnt/c/ai_models
# - 輸出 (訓練/批次/故事產物/大量媒體) -> /mnt/c/ai_output/<project>

# Cache root (HF/torch/XDG cache lives here; do NOT put large models under $HOME)
AI_CACHE_ROOT=/mnt/c/ai_cache

# Model root (managed weights / LoRAs / checkpoints)
AI_MODELS_ROOT=/mnt/c/ai_models

# Output root (project outputs / runs)
AI_OUTPUT_ROOT=/mnt/c/ai_output/anime-adventure-lab

# Optional: dataset + RAG roots (defaults are derived from AI_DATA_ROOT + project slug)
AI_DATA_ROOT=/mnt/c/ai_data
AI_DATASETS_ROOT=/mnt/c/ai_datasets/anime-adventure-lab
AI_RAG_ROOT=/mnt/c/ai_output/anime-adventure-lab/rag
AI_WORLDPACKS_ROOT=/mnt/c/ai_datasets/anime-adventure-lab/worldpacks

# Enforce caches away from $HOME/.cache (recommended)
HF_HOME=/mnt/c/ai_cache/huggingface
TRANSFORMERS_CACHE=/mnt/c/ai_cache/huggingface
TORCH_HOME=/mnt/c/ai_cache/torch
XDG_CACHE_HOME=/mnt/c/ai_cache

# ============================================================================
# API Configuration
# ============================================================================

# API server settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# Native local frontend/dev-server settings
FRONTEND_PORT=3000
VITE_API_BASE=/api/v1
VITE_PROXY_TARGET=http://127.0.0.1:8000
START_WORKER=0
START_REDIS=0

# CORS allowed origins (comma-separated)
API_CORS_ORIGINS=http://localhost:3000

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL connection
DATABASE_URL=postgresql://saga:change-me@localhost:5432/sagaforge
POSTGRES_DB=sagaforge
POSTGRES_USER=saga
POSTGRES_PASSWORD=change-me

# ============================================================================
# Redis Configuration
# ============================================================================

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Redis cache settings
REDIS_MAX_CONNECTIONS=20
REDIS_CACHE_TTL=3600

# ============================================================================
# Object Storage (MinIO/S3)
# ============================================================================

# MinIO/S3 configuration (optional)
MINIO_ENDPOINT=localhost:9000
MINIO_USER=sagaforge
MINIO_PASSWORD=change-me
MINIO_BUCKET=sagaforge
MINIO_USE_SSL=false

# ============================================================================
# AI Model Configuration
# ============================================================================

# Mock mode (DEFAULT: 0=real GPU/local models, 1=stub/mock mode)
# Set to 1 only for tests or machines without model/GPU support.
T2I_MOCK=0              # Text-to-Image mock mode
VLM_MOCK=0              # Vision-Language Model mock mode
LLM_MOCK=0              # Language Model mock mode

# Default models (only loaded when mock mode is disabled)
LOCAL_MODEL_ONLY=1
MODEL_CHAT_MODEL=/mnt/c/ai_models/language/llm/Qwen2.5-7B-Instruct
MODEL_DEFAULT_LLM=/mnt/c/ai_models/language/llm/Qwen2.5-7B-Instruct
MODEL_EMBEDDING_MODEL=/mnt/c/ai_models/language/sentence_transformers/bge-m3
MODEL_DEFAULT_SD_MODEL=/mnt/c/ai_models/diffusion/stable-diffusion/stable-diffusion-xl-base-1.0
MODEL_CAPTION_MODEL=/mnt/c/ai_models/language/vlm/gemma-4-E4B-it
MODEL_VQA_MODEL=/mnt/c/ai_models/language/vlm/gemma-4-E4B-it
RAG_EMBEDDING_MODEL=/mnt/c/ai_models/language/sentence_transformers/bge-m3
RAG_RERANKER_MODEL=/mnt/c/ai_models/language/reranker/bge-reranker-large

# Model precision
MODEL_DEVICE=cuda
MODEL_DEVICE_MAP=auto
MODEL_TORCH_DTYPE=float16
MODEL_USE_4BIT_LOADING=true
MODEL_MAX_MEMORY_GB=14
MODEL_PRECISION=fp16  # or bf16, int8, int4

# Performance settings
ENABLE_XFORMERS=true
ENABLE_ATTENTION_SLICING=false
LOW_VRAM_MODE=false

# ============================================================================
# Performance & Optimization
# ============================================================================

# Quantization mode (none, int8, int4, dynamic)
QUANTIZATION_MODE=int8

# Batch processing
MAX_BATCH_SIZE=32
OPTIMAL_BATCH_SIZE=8
ENABLE_BATCH_DEDUPLICATION=true

# Caching
EMBEDDING_CACHE_TTL=604800  # 7 days in seconds
IMAGE_CACHE_TTL=259200  # 3 days in seconds
ENABLE_KV_CACHE=true

# ============================================================================
# GPU Configuration
# ============================================================================

# CUDA device selection (comma-separated device IDs, or empty for all)
CUDA_VISIBLE_DEVICES=0

# GPU memory settings
GPU_MEMORY_FRACTION=0.9

# ============================================================================
# Celery Worker Configuration
# ============================================================================

# Celery broker URL
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Worker settings
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_TASK_TIME_LIMIT=3600  # 1 hour in seconds

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log

# Enable detailed logging
ENABLE_DEBUG_LOGGING=false

# ============================================================================
# Security Configuration
# ============================================================================

# API authentication (optional)
ENABLE_API_AUTH=false
API_ADMIN_USERNAME=admin
# Generate with: python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('change-me'))"
API_ADMIN_PASSWORD_HASH=
API_SESSION_SECRET=
API_COOKIE_SECURE=false
LOG_FORMAT=text
LOG_LEVEL=INFO
API_SECRET_KEY=your-secret-key-here-change-in-production
API_TRUSTED_HOSTS=localhost,127.0.0.1,testserver,api
API_RATE_LIMIT_PER_MINUTE=120
API_LOGIN_RATE_LIMIT_PER_MINUTE=10
# Keep API discovery private unless this is an intentionally public service.
PUBLIC_API_DOCS=false
# Enable only behind a trusted reverse proxy that overwrites forwarded headers.
TRUST_PROXY_HEADERS=false

# Generic Agent tools are intentionally disabled. Domain-specific story/world
# Agent endpoints do not require these switches.
AGENT_ENABLE_GENERIC_TOOL_API=0
AGENT_ENABLE_FILE_TOOLS=0
STORY_RUNTIME_MODE=llm
RAG_RUNTIME_MODE=model
WORKER_PROFILE=core
JOB_MAX_ATTEMPTS=3
JOB_DISPATCH_GRACE_SECONDS=10
RAG_STORY_TOP_K=4
# Demo-only pacing; leave 0 in normal production.
DEMO_JOB_DELAY_MS=0
# If file tools are explicitly enabled, provide os.pathsep-separated roots.
AGENT_FILE_ROOTS=

# Rate limiting
API_RATE_LIMIT=100/minute

# Upload limits
MAX_UPLOAD_SIZE_MB=100

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/disable specific features
ENABLE_RAG=true
ENABLE_T2I=true
ENABLE_VLM=true
ENABLE_TRAINING=true
ENABLE_BATCH_JOBS=true

# Safety features
ENABLE_CONTENT_FILTER=true
ENABLE_NSFW_FILTER=true
WATERMARK_IMAGES=false

# ============================================================================
# External Services
# ============================================================================

# HuggingFace token (for private models)
HF_TOKEN=

# Weights & Biases (optional, for training monitoring)
WANDB_API_KEY=
WANDB_PROJECT=anime-adventure-lab

# ============================================================================
# Development Settings
# ============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Enable hot reload
AUTO_RELOAD=true

# Debug mode
DEBUG=false

# ============================================================================
# Monitoring & Observability
# ============================================================================

# Enable Prometheus metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Sentry error tracking (optional)
SENTRY_DSN=

# ============================================================================
# Story & World Configuration
# ============================================================================

# Default world settings
DEFAULT_WORLD_ID=demo_world
MAX_STORY_TURNS=100

# Narrative settings
NARRATIVE_STYLE=balanced  # minimal, balanced, detailed, rich
CHARACTER_CONSISTENCY_CHECK=true

# ============================================================================
# Frontend Configuration
# ============================================================================

# React (Vite) dev server runs at http://localhost:3000 (see frontend/react/vite.config.ts)

# ============================================================================
# Testing Configuration
# ============================================================================

# Test database (use separate DB for tests)
TEST_DATABASE_URL=postgresql://saga:saga123@localhost:5432/sagaforge_test

# Test settings
RUN_SLOW_TESTS=false
TEST_WITH_REAL_MODELS=false
# Public case-study port (separate from the authenticated React workbench)
PORTFOLIO_PORT=8081
